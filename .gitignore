    t.ElemDesc              = Color3.fromRGB(98, 98, 128)
    t.Text                  = Color3.fromRGB(18, 18, 38)
    t.SubText               = Color3.fromRGB(98, 98, 128)
    t.InputBg               = Color3.fromRGB(238, 238, 252)
    t.InputBgFocused        = Color3.fromRGB(228, 228, 248)
